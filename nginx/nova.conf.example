# Nova reference nginx configuration — TWO-VHOST split.
#
# This is the documentation companion to the wizard-rendered template
# (internal/setup/templates/nova.conf.tmpl). The M13 first-run wizard
# renders an equivalent two-vhost config from operator answers; this file
# is the hand-editable reference for operators who front Nova with their
# own nginx instead of the compose stack.
#
# WHY TWO VHOSTS (THREAT_MODEL.md boundary ①): the public-content origin
# and the admin origin live on DISTINCT virtual hosts so that an XSS or
# cache-poisoning at the public origin cannot become administrative trust.
# Each vhost closes its default location to 404 — the public host never
# proxies /admin or /api/v1/admin, and the admin host never proxies the
# content/upload routes. The coordinator keeps a single mux; the host
# split is enforced entirely here at nginx.
#
# Drop this file into /etc/nginx/conf.d/ (or include it from your main
# nginx.conf). The directives at the top are http-context directives;
# conf.d files are already inside http { } in the default nginx layout.
#
# Placeholders to replace:
#   {{PUBLIC_HOST}}    public content hostname (e.g., img.example.com)
#   {{ADMIN_HOST}}     admin hostname (e.g., admin.example.com); MAY be the
#                      same name on a different listen address — keep the two
#                      server blocks distinct either way
#   {{SSL_CERT_PATH}}  fullchain certificate (PEM)
#   {{SSL_KEY_PATH}}   private key (PEM)
#   {{ADMIN_LISTEN}}   admin HTTPS listen (e.g., 127.0.0.1:8445 to keep admin
#                      loopback-only, or 443 if {{ADMIN_HOST}} is a distinct name)
#   {{COORDINATOR}}    upstream coordinator address (default 127.0.0.1:9000)
#
# Validate after editing:  nginx -t

# ===========================================================================
# Rate-limit zones
# ===========================================================================

# Per-IP general limit. 30 req/s sustained, with bursts handled at
# location-level burst settings.
limit_req_zone $binary_remote_addr zone=nova_per_ip:10m rate=30r/s;

# Per-IP upload limit. Stricter; uploads are expensive.
limit_req_zone $binary_remote_addr zone=nova_uploads:10m rate=5r/s;

# Per-authenticated-user limit. The coordinator sets the
# X-Nova-User-Id response header; we echo it into the request via a
# map for use as a rate-limit key. Falls back to remote_addr for
# unauthenticated traffic.
map $http_authorization $nova_user_key {
    default $binary_remote_addr;
    ~^Bearer\s+(?<token>.+)$ $token;
}
limit_req_zone $nova_user_key zone=nova_per_user:10m rate=60r/s;

# ===========================================================================
# Content cache
# ===========================================================================
#
# /blob/* and /i/* responses are content-addressed and immutable, so
# we cache aggressively. 7-day inactive timeout is conservative;
# operators with disk-rich edges can raise it.

proxy_cache_path /var/cache/nginx/nova
                 levels=1:2
                 keys_zone=nova_content:64m
                 max_size=2g
                 inactive=7d
                 use_temp_path=off;

# ===========================================================================
# Upstream
# ===========================================================================

upstream nova_coordinator {
    server {{COORDINATOR}};
    keepalive 32;
}

# ===========================================================================
# HTTP → HTTPS redirect (also serves ACME http-01 challenges)
# ===========================================================================

server {
    listen 80;
    listen [::]:80;
    server_name {{PUBLIC_HOST}};

    location /.well-known/acme-challenge/ {
        root /var/lib/certbot/webroot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ===========================================================================
# PUBLIC HTTPS server — public_host
# ===========================================================================
#
# Serves content, public uploads, public legal endpoints, the hermetic
# upload widget, and an ACL-restricted /metrics. The default location is
# CLOSED (404): nothing falls through to the coordinator that is not
# explicitly listed below. /admin and /api/v1/admin are NOT served here.

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{PUBLIC_HOST}};

    # ----- TLS ----------------------------------------------------------
    ssl_certificate     {{SSL_CERT_PATH}};
    ssl_certificate_key {{SSL_KEY_PATH}};

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE+AESGCM:ECDHE+CHACHA20:ECDHE+AES;
    ssl_prefer_server_ciphers off;

    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 1.1.1.1 9.9.9.9 valid=300s;
    resolver_timeout 5s;

    # ----- Security headers --------------------------------------------
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "interest-cohort=(), browsing-topics=()" always;

    # CSP. The widget bundle and admin SPA are hermetic;
    # default-src 'self' is enforceable.
    add_header Content-Security-Policy
        "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        always;

    server_tokens off;

    # ----- Body and timeouts -------------------------------------------
    client_max_body_size 100m;
    client_body_timeout 300s;
    client_header_timeout 30s;
    keepalive_timeout 75s;
    send_timeout 60s;

    # ----- Common proxy headers ----------------------------------------
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Real-IP $remote_addr;

    # ----- Health probe -------------------------------------------------
    location = /health {
        access_log off;
        proxy_pass http://nova_coordinator;
    }

    # ----- Content endpoints (cacheable, immutable) --------------------
    #
    # These responses set Cache-Control: public, max-age=31536000,
    # immutable. nginx caches downstream responses honouring those
    # headers; a CDN in front of nginx caches the same way.
    location ~ ^/(blob|i)/ {
        limit_req zone=nova_per_ip burst=120 nodelay;

        proxy_pass http://nova_coordinator;

        proxy_cache nova_content;
        proxy_cache_valid 200 206 1y;
        proxy_cache_valid 410 1h;
        proxy_cache_valid 401 1m;
        proxy_cache_valid any 10s;
        proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
        proxy_cache_lock on;
        proxy_cache_revalidate on;
        proxy_cache_background_update on;
        proxy_force_ranges on;

        add_header X-Cache-Status $upstream_cache_status always;
    }

    # ----- Public legal endpoints --------------------------------------
    location /legal/ {
        limit_req zone=nova_per_ip burst=10 nodelay;
        proxy_pass http://nova_coordinator;
    }

    # ----- Upload endpoints (streamed, stricter limit) -----------------
    #
    # Only the public content upload routes are exposed here; the admin
    # API lives on the admin vhost below.
    location ~ ^/api/v1/(uploads|blobs|images)(/|$) {
        limit_req zone=nova_uploads burst=20 nodelay;

        proxy_pass http://nova_coordinator;
        proxy_request_buffering off;
        proxy_buffering off;
    }

    # ----- Upload widget (M12) -----------------------------------------
    #
    # The coordinator serves the hermetic widget bundle + demo at /widget/*
    # when NOVA_WIDGET_DIST_DIR is set (unset ⇒ 404). The widget is the
    # end-user uploader and belongs on the PUBLIC host (its API target,
    # /api/v1/uploads/*, is a public-origin route) — never on the admin host.
    location /widget {
        limit_req zone=nova_per_ip burst=30 nodelay;
        proxy_pass http://nova_coordinator;
    }

    # ----- Federation endpoints: NEVER expose publicly -----------------
    #
    # /fed/v1/* is reachable only over the Nebula mesh. Block at the
    # public reverse proxy as a defense-in-depth measure; the
    # coordinator also binds the federation endpoint to the Nebula
    # interface only.
    location /fed/ {
        return 404;
    }

    # ----- Metrics: ACL-restricted -------------------------------------
    #
    # The Prometheus metrics endpoint is loopback-only on the
    # coordinator. If you scrape from a host on a private subnet,
    # adjust the allow lines below. The default denies the public
    # internet.
    location /metrics {
        allow 127.0.0.1;
        # allow 10.0.0.0/8;     # uncomment if your scraper is on RFC 1918
        # allow 172.16.0.0/12;
        # allow 192.168.0.0/16;
        deny all;

        access_log off;
        proxy_pass http://nova_coordinator;
    }

    # ----- Default: CLOSED on the public vhost -------------------------
    #
    # Anything not explicitly matched above is refused. In particular,
    # /admin and /api/v1/admin are not reachable from the public origin.
    location / {
        return 404;
    }
}

# ===========================================================================
# ADMIN HTTPS server — admin_host (separate vhost; not for the public internet)
# ===========================================================================
#
# Serves the admin SPA, the admin/auth API, and the current-user endpoint.
# Bind it loopback-only ({{ADMIN_LISTEN}} = 127.0.0.1:8445) or to a distinct
# admin hostname, and IP-restrict or mTLS-front it independently. The default
# location is CLOSED (404): content, uploads, and the widget are NOT served
# here.

server {
    listen {{ADMIN_LISTEN}} ssl;
    listen [::]:{{ADMIN_LISTEN}} ssl;
    http2 on;
    server_name {{ADMIN_HOST}};

    # ----- TLS ----------------------------------------------------------
    ssl_certificate     {{SSL_CERT_PATH}};
    ssl_certificate_key {{SSL_KEY_PATH}};

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE+AESGCM:ECDHE+CHACHA20:ECDHE+AES;
    ssl_prefer_server_ciphers off;

    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # ----- Security headers --------------------------------------------
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "interest-cohort=(), browsing-topics=()" always;

    add_header Content-Security-Policy
        "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        always;

    server_tokens off;

    # ----- Body and timeouts -------------------------------------------
    client_max_body_size 100m;
    client_body_timeout 300s;
    client_header_timeout 30s;
    keepalive_timeout 75s;
    send_timeout 60s;

    # ----- Common proxy headers ----------------------------------------
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Real-IP $remote_addr;

    # ----- Health probe -------------------------------------------------
    location = /health {
        access_log off;
        proxy_pass http://nova_coordinator;
    }

    # ----- Admin SPA ---------------------------------------------------
    location /admin {
        limit_req zone=nova_per_ip burst=30 nodelay;
        proxy_pass http://nova_coordinator;
    }

    # ----- Admin API ---------------------------------------------------
    location /api/v1/admin/ {
        limit_req zone=nova_per_user burst=60 nodelay;
        proxy_pass http://nova_coordinator;
    }

    # ----- Auth endpoints ----------------------------------------------
    location /api/v1/auth/ {
        limit_req zone=nova_per_user burst=60 nodelay;
        proxy_pass http://nova_coordinator;
    }

    # ----- Current-user endpoint ---------------------------------------
    location = /api/v1/users/me {
        limit_req zone=nova_per_user burst=60 nodelay;
        proxy_pass http://nova_coordinator;
    }

    # ----- Federation endpoints: NEVER expose publicly -----------------
    location /fed/ {
        return 404;
    }

    # ----- Default: CLOSED on the admin vhost --------------------------
    location / {
        return 404;
    }
}
