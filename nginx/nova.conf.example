# Nova reference nginx configuration.
#
# Drop this file into /etc/nginx/conf.d/ (or include it from your
# main nginx.conf). The directives at the top are http-context
# directives; conf.d files are already inside http { } in the
# default nginx layout, so they are valid here.
#
# Placeholders to replace:
#   {{HOST}}           public hostname (e.g., img.example.com)
#   {{SSL_CERT_PATH}}  fullchain certificate (PEM)
#   {{SSL_KEY_PATH}}   private key (PEM)
#   {{COORDINATOR}}    upstream coordinator address (default 127.0.0.1:8080)
#
# Validate after editing:  nginx -t

# ===========================================================================
# Rate-limit zones
# ===========================================================================

# Per-IP general limit. 30 req/s sustained, with bursts handled at
# location-level burst settings.
limit_req_zone $binary_remote_addr zone=nova_per_ip:10m rate=30r/s;

# Per-IP upload limit. Stricter; uploads are expensive.
limit_req_zone $binary_remote_addr zone=nova_uploads:10m rate=5r/s;

# Per-authenticated-user limit. The coordinator sets the
# X-Nova-User-Id response header; we echo it into the request via a
# map for use as a rate-limit key. Falls back to remote_addr for
# unauthenticated traffic.
map $http_authorization $nova_user_key {
    default $binary_remote_addr;
    ~^Bearer\s+(?<token>.+)$ $token;
}
limit_req_zone $nova_user_key zone=nova_per_user:10m rate=60r/s;

# ===========================================================================
# Content cache
# ===========================================================================
#
# /blob/* and /i/* responses are content-addressed and immutable, so
# we cache aggressively. 7-day inactive timeout is conservative;
# operators with disk-rich edges can raise it.

proxy_cache_path /var/cache/nginx/nova
                 levels=1:2
                 keys_zone=nova_content:64m
                 max_size=2g
                 inactive=7d
                 use_temp_path=off;

# ===========================================================================
# Upstream
# ===========================================================================

upstream nova_coordinator {
    server {{COORDINATOR}};
    keepalive 32;
}

# ===========================================================================
# HTTP → HTTPS redirect (also serves ACME http-01 challenges)
# ===========================================================================

server {
    listen 80;
    listen [::]:80;
    server_name {{HOST}};

    location /.well-known/acme-challenge/ {
        root /var/lib/certbot/webroot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ===========================================================================
# Main HTTPS server
# ===========================================================================

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{HOST}};

    # ----- TLS ----------------------------------------------------------
    ssl_certificate     {{SSL_CERT_PATH}};
    ssl_certificate_key {{SSL_KEY_PATH}};

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE+AESGCM:ECDHE+CHACHA20:ECDHE+AES;
    ssl_prefer_server_ciphers off;

    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 1.1.1.1 9.9.9.9 valid=300s;
    resolver_timeout 5s;

    # ----- Security headers --------------------------------------------
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "interest-cohort=(), browsing-topics=()" always;

    # CSP for the admin SPA. The widget bundle and admin SPA are
    # hermetic; default-src 'self' is enforceable.
    add_header Content-Security-Policy
        "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        always;

    server_tokens off;

    # ----- Body and timeouts -------------------------------------------
    client_max_body_size 100m;
    client_body_timeout 300s;
    client_header_timeout 30s;
    keepalive_timeout 75s;
    send_timeout 60s;

    # ----- Common proxy headers ----------------------------------------
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Real-IP $remote_addr;

    # ----- Health probe -------------------------------------------------
    location = /health {
        access_log off;
        proxy_pass http://nova_coordinator;
    }

    # ----- Content endpoints (cacheable, immutable) --------------------
    #
    # These responses set Cache-Control: public, max-age=31536000,
    # immutable. nginx caches downstream responses honouring those
    # headers; a CDN in front of nginx caches the same way.
    location ~ ^/(blob|i)/ {
        limit_req zone=nova_per_ip burst=120 nodelay;

        proxy_pass http://nova_coordinator;

        proxy_cache nova_content;
        proxy_cache_valid 200 206 1y;
        proxy_cache_valid 410 1h;
        proxy_cache_valid 401 1m;
        proxy_cache_valid any 10s;
        proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
        proxy_cache_lock on;
        proxy_cache_revalidate on;
        proxy_cache_background_update on;
        proxy_force_ranges on;

        add_header X-Cache-Status $upstream_cache_status always;
    }

    # ----- Upload endpoints (streamed, stricter limit) -----------------
    location ~ ^/api/v1/(uploads|blobs|images)(/|$) {
        limit_req zone=nova_uploads burst=20 nodelay;

        proxy_pass http://nova_coordinator;
        proxy_request_buffering off;
        proxy_buffering off;
    }

    # ----- Management API ----------------------------------------------
    location /api/v1/ {
        limit_req zone=nova_per_user burst=60 nodelay;
        proxy_pass http://nova_coordinator;
    }

    # ----- Public legal endpoints --------------------------------------
    location /legal/ {
        limit_req zone=nova_per_ip burst=10 nodelay;
        proxy_pass http://nova_coordinator;
    }

    # ----- Admin SPA ---------------------------------------------------
    #
    # Operators concerned about exposing /admin to the public internet
    # may bind the admin SPA to a separate hostname (admin.example.com)
    # served by a different server block, or restrict by IP. The
    # default below proxies it through; rely on Authelia bearer auth
    # and CSP for protection.
    location /admin {
        limit_req zone=nova_per_ip burst=30 nodelay;
        proxy_pass http://nova_coordinator;
    }

    # ----- Federation endpoints: NEVER expose publicly -----------------
    #
    # /fed/v1/* is reachable only over the Nebula mesh. Block at the
    # public reverse proxy as a defense-in-depth measure; the
    # coordinator also binds the federation endpoint to the Nebula
    # interface only.
    location /fed/ {
        return 404;
    }

    # ----- Metrics: ACL-restricted -------------------------------------
    #
    # The Prometheus metrics endpoint is loopback-only on the
    # coordinator. If you scrape from a host on a private subnet,
    # adjust the allow lines below. The default denies the public
    # internet.
    location /metrics {
        allow 127.0.0.1;
        # allow 10.0.0.0/8;     # uncomment if your scraper is on RFC 1918
        # allow 172.16.0.0/12;
        # allow 192.168.0.0/16;
        deny all;

        access_log off;
        proxy_pass http://nova_coordinator;
    }

    # ----- Default: pass through to coordinator ------------------------
    location / {
        limit_req zone=nova_per_ip burst=30 nodelay;
        proxy_pass http://nova_coordinator;
    }
}
