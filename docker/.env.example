# Nova docker-compose environment.
# Copy to docker/.env and set values. docker/.env is gitignored.
#
# SECRETS NOTE: The master key, IPFS swarm key, and OIDC signing key are
# GENERATED by the setup wizard and written into the nova-secrets volume
# (/run/secrets inside the container). Do NOT set them here — the wizard
# stages them automatically on first run.

# ── Required ──────────────────────────────────────────────────────────────────

# Postgres superuser password. Generate a strong one:
#   openssl rand -base64 32
POSTGRES_PASSWORD=changeme

# ── Optional overrides ────────────────────────────────────────────────────────
# These have sensible defaults in docker-compose.yml; override here only if
# you deviate from the standard volume-mount layout.

# On-disk path for operator config (operator.yaml, nova.conf, tls/, sentinel).
# Default: /etc/nova  (mapped from the nova-config named volume)
# NOVA_CONFIG_DIR=/etc/nova

# On-disk path for generated secrets (master-key-v1, swarm.key, oidc-signing-key).
# Default: /run/secrets  (mapped from the nova-secrets named volume)
# NOVA_SECRETS_DIR=/run/secrets

# Kubo (IPFS) repo directory.
# Default: /var/lib/nova/kubo  (mapped from the nova-kubo named volume)
# NOVA_KUBO_REPO=/var/lib/nova/kubo

# tus upload temp dir.
# Default: /var/tmp/nova-uploads  (mapped from the nova-tmp named volume)
# NOVA_UPLOAD_TMP_DIR=/var/tmp/nova-uploads

# Coordinator HTTP listen address.
# Default: :9000  (not published externally; nginx fronts it)
# NOVA_LISTEN_ADDR=:9000

# Comma-separated IPs/CIDRs of trusted reverse proxies (sets X-Forwarded-For).
# Default: 127.0.0.1/32,::1/128  (nginx on the same compose network)
# NOVA_TRUSTED_PROXIES=127.0.0.1/32,::1/128
